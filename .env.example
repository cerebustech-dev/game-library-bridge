# Copy to .env and fill in. NEVER commit .env (it is gitignored).

# --- Secrets -----------------------------------------------------------------
# Steam Web API key. Get one at https://steamcommunity.com/dev/apikey
# Required for owned games + playtime. In GitHub Actions, set this as the
# repository secret STEAM_API_KEY instead of committing it anywhere.
STEAM_API_KEY=

# --- Identity ----------------------------------------------------------------
# 64-bit SteamID whose owned games are exported. Profile game details must be
# public (Steam profile privacy settings -> Game details -> Public).
STEAM_ID=76561197970928054

# IsThereAnyDeal public profile user id, i.e. the <uid> in
# https://isthereanydeal.com/uid/<uid>/collection/
ITAD_USER=arcca

# --- Output ------------------------------------------------------------------
# Where the versioned snapshot is written.
OUTPUT_PATH=public/games.json

# --- Snapshot guard ----------------------------------------------------------
# A new snapshot is rejected if a list shrinks below this fraction of the
# previous snapshot (protects against silently truncated fetches).
GUARD_MIN_RATIO=0.5
# Lists at or below this size only guard against becoming empty, not ratio.
GUARD_SMALL_LIST=10

# --- ITAD fetch strategy -----------------------------------------------------
# 1 = skip the direct JSON endpoints and go straight to the Playwright
# fallback (requires: pip install .[browser] && playwright install chromium)
ITAD_USE_PLAYWRIGHT=0

# --- Logging -----------------------------------------------------------------
# json (structured, one object per line, for CI) or text (human friendly)
LOG_FORMAT=text
LOG_LEVEL=INFO
